{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ochilar",
  "version": "0.1.0",
  "identifier": "com.ochilar.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "overlay",
        "title": "Ochilar",
        "url": "index.html",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": true,
        "width": 1918,
        "height": 1078,
        "x": 1,
        "y": 1
      },
      {
        "label": "dim_layer",
        "title": "OchilarDimLayer",
        "url": "dim.html",
        "transparent": false,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": true,
        "width": 1918,
        "height": 1078,
        "x": 1,
        "y": 1
      },
      {
        "label": "drift_layer",
        "title": "OchilarDriftLayer",
        "url": "drift.html",
        "transparent": false,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": true,
        "width": 1918,
        "height": 1078,
        "x": 1,
        "y": 1
      },
      {
        "label": "debug",
        "title": "Ochilar — debug",
        "url": "debug.html",
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": true,
        "resizable": true,
        "visible": true,
        "width": 320,
        "height": 360,
        "x": 100,
        "y": 100
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
